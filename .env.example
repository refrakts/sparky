# ─── Required ─────────────────────────────────────────────────────────
# Sparkscan API base URL (defaults to https://api.sparkscan.io)
# SPARKSCAN_API_URL=https://api.sparkscan.io

# ─── Site ────────────────────────────────────────────────────────────
# Canonical site URL (used for SEO metadata, sitemap, robots.txt)
NEXT_PUBLIC_SITE_URL=https://sparky-eta.vercel.app

# ─── AI (Vercel AI Gateway) ───────────────────────────────────────────
# On Vercel: authentication is automatic via OIDC (no key needed).
# For local dev: create a key at https://vercel.com/~/ai-gateway/api-keys
AI_GATEWAY_API_KEY=...
