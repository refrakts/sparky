{
    "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "useExhaustiveDependencies": "off",
                "noUnusedImports": "warn"
            },
            "suspicious": {
                "noExplicitAny": "off",
                "noArrayIndexKey": "off",
                "useIterableCallbackReturn": "off"
            },
            "style": {
                "noNonNullAssertion": "off"
            },
            "performance": {
                "noImgElement": "off"
            },
            "a11y": {
                "noSvgWithoutTitle": "off",
                "useValidAriaRole": "off",
                "useSemanticElements": "off",
                "noStaticElementInteractions": "off",
                "useKeyWithClickEvents": "off"
            },
            "security": {
                "noDangerouslySetInnerHtml": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all",
            "arrowParentheses": "always"
        }
    },
    "json": {
        "formatter": {
            "indentWidth": 4
        }
    },
    "css": {
        "linter": {
            "enabled": false
        },
        "formatter": {
            "enabled": false
        },
        "parser": {
            "cssModules": true
        }
    },
    "files": {
        "includes": ["src/**/*.ts", "src/**/*.tsx", "*.json"]
    }
}
